SONIOX_API_KEY=
DEEPSEEK_API_KEY=

# Vision describer for take_screenshot / capture_webcam.
# DeepSeek's chat models do not accept image input — verified empirically —
# so vision is configured separately in server/config.yaml. The default in
# config.yaml is Kimi/Moonshot's vision-preview, which speaks the OpenAI
# image_url content-block format.
#
# Whichever provider config.yaml points at, set its key here. The default
# (provider: kimi) reads MOONSHOT_API_KEY:
MOONSHOT_API_KEY=

# Alternates — set the matching key only if you swap config.yaml's vision
# provider to one of these:
OPENAI_API_KEY=

# Optional. Required for the web_search tool (Serper / Google).
SERPER_API_KEY=

# Optional. Where to write per-session structured logs (kebab-case JSONL).
# Defaults to ./logs relative to wherever local_bot.py is run.
VOICE_BOT_LOG_DIR=
